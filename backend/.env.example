# 複製為 .env 後填入真實值（勿提交 .env 到 Git）

SECRET_KEY=change-me-in-production
GEMINI_API_KEY=

# AI 付費權限：plan_code 須在此清單內（逗號分隔，小寫比對）
AI_PAID_PLAN_CODES=pro,premium,paid,member,vip

# 總帳號／內部測試：username 在此清單則無限使用 AI（逗號分隔，不分大小寫）
# 另：資料庫 users.role = admin 也一律放行
AI_UNLIMITED_USERNAMES=

# 選用：美股資料
FINNHUB_API_KEY=

# ========== 藍新金流 NewebPay MPG ==========
# 商店後台：會員中心 → 商店管理 → 串接設定（測試/正式金鑰不同）
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
# test（預設）或 prod / production / live
NEWEBPAY_ENV=test

# 各方案台幣金額（整數）；未填則用內建預設
# NEWEBPAY_AMT_1M=99
# NEWEBPAY_AMT_6M=475
# NEWEBPAY_AMT_12M=833

# 付款成功後寫入 users.plan_code（須在 AI_PAID_PLAN_CODES 內）
NEWEBPAY_PAID_PLAN_CODE=premium

# 藍新 Notify/Return 會打這個「公開網址」（本機請用 ngrok / cloudflared）
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# 付款完成導回的前端網址
PUBLIC_FRONTEND_URL=http://localhost:3000
